--!strict

type StatListenerEntry = {
  stat: Property<number>,
  cb: () -> (),
}

type KeyListenerEntry = {
  name: Property<string>?,
  id: Property<string>?,
  cb: () -> (),
}

type ItemSnapshot = {
  strings: { [string]: string },
  numbers: { [string]: number },
}

type Sorter = {
  vm: Data.Main?,
  list: PropertyList?,
  sortByStat: Property<number>?,
  sortType: Property<number>?,
  statListeners: { [Data.Item]: StatListenerEntry },
  keyListeners: { [Data.Item]: KeyListenerEntry },
  trackedStat: number,
  context: Context?,
  onListChanged: (() -> ())?,
  onSortChanged: (() -> ())?,
  originalOrder: { Data.Item },
  originalRank: { [Data.Item]: number },
  itemKeys: { [Data.Item]: string },
  isRefreshing: boolean,
  needsRefresh: boolean,
}

local STRING_FIELDS = { "id", "name", "image", "imageUrl" }
local NUMBER_FIELDS = {
  "stat1",
  "stat2",
  "stat3",
  "stat4",
  "stat5",
  "stat6",
  "stat7",
  "stat8",
}

local refresh: (Sorter) -> ()

local function requestRefresh(self: Sorter)
  if self.isRefreshing then
    return
  end

  self.needsRefresh = true
  if self.context then
    self.context:markNeedsUpdate()
  else
    refresh(self)
  end
end

local function getString(item: Data.Item, key: string): string
  local prop = item:getString(key)
  if prop then
    return prop.value
  end
  return ""
end

local function getItemKey(item: Data.Item): string
  local name = getString(item, "name")
  if name ~= "" then
    return name
  end
  return getString(item, "id")
end

local function getNumber(item: Data.Item, key: string): number
  local prop = item:getNumber(key)
  if prop then
    return prop.value
  end
  return 0
end

local function snapshotItem(item: Data.Item): ItemSnapshot
  local snapshot: ItemSnapshot = { strings = {}, numbers = {} }

  for _, key in STRING_FIELDS do
    local prop = item:getString(key)
    if prop then
      snapshot.strings[key] = prop.value
    end
  end

  for _, key in NUMBER_FIELDS do
    local prop = item:getNumber(key)
    if prop then
      snapshot.numbers[key] = prop.value
    end
  end

  return snapshot
end

local function applySnapshot(item: Data.Item, snapshot: ItemSnapshot)
  for key, value in snapshot.strings do
    local prop = item:getString(key)
    if prop and prop.value ~= value then
      prop.value = value
    end
  end

  for key, value in snapshot.numbers do
    local prop = item:getNumber(key)
    if prop and prop.value ~= value then
      prop.value = value
    end
  end
end

local function captureCurrentOrder(self: Sorter)
  local list = self.list
  if not list then
    return
  end

  self.originalOrder = {}
  self.originalRank = {}
  for i = 1, list.length do
    local item = list[i] :: Data.Item
    self.originalOrder[i] = item
    self.originalRank[item] = i
  end
end

local function captureOriginalOrder(self: Sorter)
  local list = self.list
  if not list then
    return
  end

  for i = 1, list.length do
    local item = list[i] :: Data.Item
    if self.originalRank[item] == nil then
      local nextRank = #self.originalOrder + 1
      self.originalOrder[nextRank] = item
      self.originalRank[item] = nextRank
    end
  end
end

local function captureItemKeys(self: Sorter)
  local list = self.list
  if not list then
    return
  end

  self.itemKeys = {}
  for i = 1, list.length do
    local item = list[i] :: Data.Item
    self.itemKeys[item] = getItemKey(item)
  end
end

local function getStat(item: Data.Item, statIndex: number): number
  if statIndex == 1 then
    return getNumber(item, "stat1")
  elseif statIndex == 2 then
    return getNumber(item, "stat2")
  elseif statIndex == 3 then
    return getNumber(item, "stat3")
  elseif statIndex == 4 then
    return getNumber(item, "stat4")
  elseif statIndex == 5 then
    return getNumber(item, "stat5")
  elseif statIndex == 6 then
    return getNumber(item, "stat6")
  elseif statIndex == 7 then
    return getNumber(item, "stat7")
  elseif statIndex == 8 then
    return getNumber(item, "stat8")
  end
  return 0
end

local function getStatProperty(
  item: Data.Item,
  statIndex: number
): Property<number>?
  if statIndex == 1 then
    return item:getNumber('stat1')
  elseif statIndex == 2 then
    return item:getNumber('stat2')
  elseif statIndex == 3 then
    return item:getNumber('stat3')
  elseif statIndex == 4 then
    return item:getNumber('stat4')
  elseif statIndex == 5 then
    return item:getNumber('stat5')
  elseif statIndex == 6 then
    return item:getNumber('stat6')
  elseif statIndex == 7 then
    return item:getNumber('stat7')
  elseif statIndex == 8 then
    return item:getNumber('stat8')
  end
  return nil
end

local function applyOrder(
  list: PropertyList,
  targetOrder: { Data.Item }
)
  local n = list.length
  if n < 2 then
    return
  end

  local current: { Data.Item } = {}
  local position: { [Data.Item]: number } = {}
  for i = 1, n do
    local item = list[i] :: Data.Item
    current[i] = item
    position[item] = i
  end

  for i = 1, #targetOrder do
    local desiredItem = targetOrder[i]
    local currentPos = position[desiredItem]
    if currentPos ~= nil and currentPos ~= i then
      local displaced = current[i]
      list:swap(i, currentPos)
      current[i] = desiredItem
      current[currentPos] = displaced
      position[desiredItem] = i
      position[displaced] = currentPos
    end
  end
end

local function applyNoSortDataOrder(self: Sorter)
  local list = self.list
  if not list then
    return
  end

  local n = list.length
  if n < 2 or next(self.itemKeys) == nil then
    captureCurrentOrder(self)
    captureItemKeys(self)
    return
  end

  local previousItemByKey: { [string]: Data.Item } = {}
  for item, key in self.itemKeys do
    if key ~= "" then
      previousItemByKey[key] = item
    end
  end

  local target: { Data.Item } = {}
  local snapshots: { ItemSnapshot } = {}
  local usedKeys: { [string]: boolean } = {}
  local usedItems: { [Data.Item]: boolean } = {}

  for i = 1, n do
    local item = list[i] :: Data.Item
    local key = getItemKey(item)
    if key == "" or usedKeys[key] then
      return
    end

    local previousItem = previousItemByKey[key]
    if previousItem ~= nil and not usedItems[previousItem] then
      target[i] = previousItem
      usedItems[previousItem] = true
    else
      target[i] = item
      usedItems[item] = true
    end

    usedKeys[key] = true
    snapshots[i] = snapshotItem(item)
  end

  applyOrder(list, target)

  -- HARDCODED VALUE: the widget rewrites leaderboard row data by index.
  -- After the scripted swap, restore each row's copied leaderboard values.
  for i = 1, n do
    local item = list[i] :: Data.Item
    applySnapshot(item, snapshots[i])
  end

  captureCurrentOrder(self)
  captureItemKeys(self)
end

local function performSort(self: Sorter)
  local list = self.list
  local sortByStat = self.sortByStat
  local sortType = self.sortType
  if not list or not sortByStat or not sortType then
    return
  end

  local mode = math.floor(sortType.value)
  local n = list.length
  if n < 2 or (mode ~= 1 and mode ~= 2) then
    return
  end

  local statIndex = math.floor(sortByStat.value)
  local ascending = mode == 2
  local items: { Data.Item } = {}
  local values: { number } = {}

  for i = 1, n do
    local item = list[i] :: Data.Item
    items[i] = item
    values[i] = getStat(item, statIndex)
  end

  local order: { number } = {}
  for i = 1, n do
    order[i] = i
  end

  local originalRank = self.originalRank
  table.sort(order, function(a: number, b: number): boolean
    local va = values[a]
    local vb = values[b]
    if va == vb then
      local ra = originalRank[items[a]] or math.huge
      local rb = originalRank[items[b]] or math.huge
      return ra < rb
    end
    if ascending then
      return va < vb
    end
    return va > vb
  end)

  local target: { Data.Item } = {}
  for i = 1, n do
    target[i] = items[order[i]]
  end
  applyOrder(list, target)
end

local function unsubscribeStatListeners(self: Sorter)
  for item, entry in self.statListeners do
    entry.stat:removeListener(entry.cb)
  end
  self.statListeners = {}
end

local function unsubscribeKeyListeners(self: Sorter)
  for item, entry in self.keyListeners do
    if entry.name then
      entry.name:removeListener(entry.cb)
    end
    if entry.id then
      entry.id:removeListener(entry.cb)
    end
  end
  self.keyListeners = {}
end

local function subscribeStatListeners(self: Sorter)
  unsubscribeStatListeners(self)

  local list = self.list
  local sortByStat = self.sortByStat
  if not list or not sortByStat then
    return
  end

  local statIndex = math.floor(sortByStat.value)
  self.trackedStat = statIndex

  local function onStatChanged()
    requestRefresh(self)
  end

  for i = 1, list.length do
    local item = list[i] :: Data.Item
    local statProp = getStatProperty(item, statIndex)
    if statProp and not self.statListeners[item] then
      statProp:addListener(onStatChanged)
      self.statListeners[item] = { stat = statProp, cb = onStatChanged }
    end
  end
end

local function subscribeKeyListeners(self: Sorter)
  unsubscribeKeyListeners(self)

  local list = self.list
  if not list then
    return
  end

  local function onKeyChanged()
    requestRefresh(self)
  end

  for i = 1, list.length do
    local item = list[i] :: Data.Item
    local nameProp = item:getString("name")
    local idProp = item:getString("id")
    if nameProp or idProp then
      if nameProp then
        nameProp:addListener(onKeyChanged)
      end
      if idProp then
        idProp:addListener(onKeyChanged)
      end
      self.keyListeners[item] = {
        name = nameProp,
        id = idProp,
        cb = onKeyChanged,
      }
    end
  end
end

refresh = function(self: Sorter)
  if self.isRefreshing then
    return
  end

  self.isRefreshing = true

  local mode = 0
  if self.sortType then
    mode = math.floor(self.sortType.value)
  end

  if mode == 0 then
    applyNoSortDataOrder(self)
  else
    captureOriginalOrder(self)
    performSort(self)
  end

  subscribeStatListeners(self)
  subscribeKeyListeners(self)
  self.isRefreshing = false
end

function init(self: Sorter, context: Context): boolean
  self.context = context
  self.statListeners = {}
  self.keyListeners = {}
  self.trackedStat = 0
  self.originalOrder = {}
  self.originalRank = {}
  self.itemKeys = {}
  self.isRefreshing = false
  self.needsRefresh = false

  local vm = context:viewModel() :: Data.Main?
  if not vm then
    return true
  end
  self.vm = vm

  self.list = vm.listProperty
  self.sortByStat = vm:getNumber('sortByStat')
  self.sortType = vm:getNumber('sortType')

  captureCurrentOrder(self)
  captureItemKeys(self)

  local function onListChanged()
    requestRefresh(self)
  end
  self.onListChanged = onListChanged

  local function onSortChanged()
    requestRefresh(self)
  end
  self.onSortChanged = onSortChanged

  if self.list then
    self.list:addListener(onListChanged)
  end
  if self.sortByStat then
    self.sortByStat:addListener(onSortChanged)
  end
  if self.sortType then
    self.sortType:addListener(onSortChanged)
  end

  refresh(self)
  return true
end

function update(self: Sorter)
  if not self.needsRefresh then
    return
  end

  self.needsRefresh = false
  refresh(self)
end

return function(): Node<Sorter>
  return {
    vm = nil,
    list = nil,
    sortByStat = nil,
    sortType = nil,
    statListeners = {},
    keyListeners = {},
    trackedStat = 0,
    context = nil,
    onListChanged = nil,
    onSortChanged = nil,
    originalOrder = {},
    originalRank = {},
    itemKeys = {},
    isRefreshing = false,
    needsRefresh = false,
    init = init,
    update = update,
  }
end
